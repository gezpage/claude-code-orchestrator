{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cat | python3 ~/.claude/hooks/session-track.py start"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cat | python3 ~/.claude/hooks/session-track.py stop"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cat | python3 ~/.claude/hooks/session-track.py prompt"
          }
        ]
      }
    ]
  }
}
