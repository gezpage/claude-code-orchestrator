{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["stage", "status"],
  "properties": {
    "stage": {"type": "string"},
    "status": {"type": "string", "enum": ["passed", "blocked", "failed"]},
    "message": {"type": "string"},
    "tracks": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {"type": "string"},
          "summary": {"type": "string"},
          "findings_file": {"type": "string"}
        }
      }
    },
    "findings_files": {"type": "array", "items": {"type": "string"}}
  },
  "additionalProperties": true
}
