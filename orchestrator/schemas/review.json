{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["stage", "status"],
  "properties": {
    "stage": {"type": "string"},
    "status": {"type": "string", "enum": ["passed", "blocked", "failed"]},
    "message": {"type": "string"},
    "reviewer_statuses": {"type": "object"},
    "changes_requested": {"type": "array", "items": {"type": "string"}},
    "review_md": {"type": "string"}
  },
  "additionalProperties": true
}
